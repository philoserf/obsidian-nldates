{
  "name": "obsidian-nldates",
  "version": "1.0.0",
  "description": "Plugin to parse natural language dates in Obsidian",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "bun run build.ts --watch",
    "build": "bun run check && bun run build.ts",
    "check": "bun run typecheck && biome check .",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test",
    "deploy": "cp main.js manifest.json ~/source/philoserf/notes/.obsidian/plugins/obsidian-nldates/",
    "validate": "bun run scripts/validate-plugin.ts",
    "version": "bun run version-bump.ts"
  },
  "author": "Mark Ayers (originally by Argentina Ortega Sainz)",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "obsidian": "^1.12.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chrono-node": "github:liamcain/chrono",
    "obsidian-daily-notes-interface": "0.9.4"
  },
  "trustedDependencies": [
    "chrono-node"
  ]
}
